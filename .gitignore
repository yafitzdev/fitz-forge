# Repository allow-list.
# Ignore everything unless it is explicitly part of the public project surface.
*

# Root files
!/.gitignore
!/CHANGELOG.md
!/CONTRIBUTING.md
!/LICENSE
!/README.md
!/pyproject.toml

# Root directories
!/.github/
!/.github/**
!/benchmarks/
!/benchmarks/**
!/docs/
!/docs/assets/
!/docs/assets/**
!/docs/features/
!/docs/features/**
!/docs/roadmap/
!/docs/roadmap/golden-plan-authoring-harness.md
!/fitz_forge/
!/fitz_forge/**
!/tests/
!/tests/**
!/tools/
!/tools/**

# Generated files and local-only state inside otherwise allowed directories
**/__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.log

.venv/
.idea/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.claude/
.planning/
.fitz-forge

dist/
build/
.coverage
htmlcov/

benchmarks/results/
benchmarks/end_to_end_results/
benchmarks/traces/
benchmarks/challenges/*/results/
benchmarks/test_*.py

docs/archive/
docs/senior-engineer-todo/

AGENTS.md
CLAUDE.md
